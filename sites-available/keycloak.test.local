# Redirect HTTP to HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name keycloak.test.local;

    return 301 https://$server_name$request_uri;
}

# Keycloak HTTPS — TLS termination, forwards to Keycloak container on port 8080.
# Keycloak is configured with KC_PROXY=edge so it trusts X-Forwarded-* headers.
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name keycloak.test.local;

    ssl_certificate     /home/nikgl/projects/keycloak/certs/keycloak.test.local/keycloak.test.local.crt;
    ssl_certificate_key /home/nikgl/projects/keycloak/certs/keycloak.test.local/keycloak.test.local.key;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         ECDHE-RSA-AES128-GCM-SHA256:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;

    access_log /var/log/nginx/keycloak.test.local.access.log;
    error_log  /var/log/nginx/keycloak.test.local.error.log;

    location / {
        proxy_pass         http://localhost:8080;
        proxy_http_version 1.1;

        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host  $host;
        proxy_set_header X-Forwarded-Port  $server_port;

        # WebSocket support (Keycloak admin console)
        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_buffering     off;
        proxy_buffer_size   4k;
    }
}
