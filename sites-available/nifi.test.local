# Redirect HTTP to HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name nifi.test.local;

    return 301 https://$server_name$request_uri;
}

# NiFi HTTPS — TLS termination, forwards to NiFi container which speaks HTTPS internally.
# NiFi uses a self-signed cert internally; proxy_ssl_verify off skips verification of that cert.
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name nifi.test.local;

    ssl_certificate     /home/nikgl/projects/keycloak/certs/wildcard.test.local/wildcard.test.local.crt;
    ssl_certificate_key /home/nikgl/projects/keycloak/certs/wildcard.test.local/wildcard.test.local.key;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         ECDHE-RSA-AES128-GCM-SHA256:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;

    access_log /var/log/nginx/nifi.test.local.access.log;
    error_log  /var/log/nginx/nifi.test.local.error.log;

    location / {
        proxy_pass            https://localhost:8443;
        proxy_http_version    1.1;
        proxy_ssl_verify      off;
        proxy_ssl_server_name on;
        proxy_ssl_name        nifi.test.local;

        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host  $host;
        proxy_set_header X-Forwarded-Port  $server_port;

        # WebSocket support (NiFi live updates)
        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection "upgrade";

        # NiFi can be slow on large flows
        proxy_read_timeout    300s;
        proxy_send_timeout    300s;
        proxy_connect_timeout  30s;

        proxy_buffering   off;
        proxy_buffer_size 4k;
    }
}
